# ── Langflow ──────────────────────────────────────────────────────
LANGFLOW_URL=http://localhost:7860
LANGFLOW_API_KEY=tu_api_key_de_langflow_aqui   # Settings → API Keys
LANGFLOW_TIMEOUT=180

# IDs de los flujos (NO cambiar — coinciden con los JSONs)
LANGFLOW_FLOW_ID_SECUENCIAL=90305752-6095-472a-af6c-d3914a57d5f8
LANGFLOW_FLOW_ID_JERARQUICO=7db32208-bb48-41c1-94f2-e1a7891cd1b6
LANGFLOW_FLOW_ID_HUMAN_LOOP=e7e08b24-9b29-4743-99d5-3cb9fab2e297
LANGFLOW_FLOW_ID_RED=                           # pendiente

# ── Google Gemini ─────────────────────────────────────────────────
GOOGLE_API_KEY=tu_google_api_key_aqui

# ── JWT ───────────────────────────────────────────────────────────
SECRET_KEY=cambia_esto_minimo_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Base de datos ─────────────────────────────────────────────────
DATABASE_URL=sqlite:///./database/tesis.db

# ── Agente Orquestador ────────────────────────────────────────────
# Si tienes un flujo separado para el orquestador en Langflow, pon su ID aquí.
# Si lo dejas vacío, se usa la detección por palabras clave (fallback automático).
LANGFLOW_FLOW_ID_ORQUESTADOR=

# IDs de los nodos de agentes en el flujo Secuencial de Langflow
# Cópialos desde Langflow: click derecho sobre el nodo → "Copy Node ID"
# Se usan para inyectar el system prompt con la rúbrica específica (efecto LoRA)
LANGFLOW_NODE_METODOLOGICO=
LANGFLOW_NODE_TECNICO=
LANGFLOW_NODE_LINGUISTICO=
LANGFLOW_NODE_CONSENSO=

# ── MCP de Rúbricas ───────────────────────────────────────────────────
# Si corres en Docker: http://mcp-rubricas:8001
# Si corres local: http://localhost:8001
MCP_RUBRICAS_URL=http://mcp-rubricas:8001
MCP_TIMEOUT=15

# ── IDs de Prompt Templates en el flujo Secuencial ───────────────────
# Corresponden al New_Flow__3_.json. Si reimportas y cambian los IDs,
# actualiza estos valores con los nuevos IDs de Langflow.
NODE_PROMPT_METODOLOGICO=Prompt Template-lExmE
NODE_PROMPT_TECNICO=Prompt Template-fvDGh
NODE_PROMPT_LINGUISTICO=Prompt Template-SYefO

NODE_PROMPT_CONSENSO=Prompt Template-9xUyA
NODE_AGENT_METODOLOGICO=DeepSeekModelComponent-XsFWz
NODE_AGENT_TECNICO=DeepSeekModelComponent-YTa3k
NODE_AGENT_LINGUISTICO=DeepSeekModelComponent-cKWsF
NODE_AGENT_CONSENSO=DeepSeekModelComponent-Iqo9x

# NOTA: Si reimportas Arquit__Secuencial.json en Langflow y los IDs cambian,
# actualiza estos 8 valores con los nuevos IDs del flujo.

# Veredicto jerárquico exhaustivo: segunda auditoría real de evidencia
JERARQUICO_AUDITORIA_EXHAUSTIVA=true
JERARQUICO_AUDITORIA_MAX_CHARS=42000
JERARQUICO_AUDITORIA_MAX_TOKENS=2600
JERARQUICO_AUDITORIA_TIMEOUT=180
